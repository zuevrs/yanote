{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yanote.dev/schemas/traceability/schema.v1.json",
  "title": "Yanote v1 requirement traceability",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "snapshotId",
    "generatedAt",
    "requirements"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "traceability.v1"
    },
    "snapshotId": {
      "type": "string",
      "pattern": "^v1-traceability-[0-9]{8}$"
    },
    "generatedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/requirementTraceability"
      }
    }
  },
  "$defs": {
    "requirementTraceability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirementId",
        "tests",
        "commands"
      ],
      "properties": {
        "requirementId": {
          "type": "string",
          "pattern": "^[A-Z]+-[0-9]+$"
        },
        "tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/testReference"
          }
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "testReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "testId",
        "path",
        "selector",
        "status"
      ],
      "properties": {
        "testId": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "selector": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "stable",
            "flaky",
            "quarantined"
          ]
        }
      }
    }
  }
}
